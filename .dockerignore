bin/
*.exe
*.dll
*.so
*.dylib

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Git
.git/
.gitignore
.github/

# Environment files
.env
.env.*

# Local config files
*.local.yaml

# CI/CD files (not needed in container)
.gitlab-ci.yml
.travis.yml
Jenkinsfile

# Kubernetes and deployment files
chart/
charts/
deployments/

# License and owners
LICENSE
OWNERS
CONTRIBUTING.md

# Temporary files
tmp/
